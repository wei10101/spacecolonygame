<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Crew Name"/>

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioPilot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilot"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 5 | Def: 4 | Energy: 20"
                android:textSize="12sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="6dp"/>

            <RadioButton
                android:id="@+id/radioEngineer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engineer"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 6 | Def: 3 | Energy: 19"
                android:textSize="12sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="6dp"/>

            <RadioButton
                android:id="@+id/radioMedic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medic"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 7 | Def: 2 | Energy: 18"
                android:textSize="12sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="6dp"/>

            <RadioButton
                android:id="@+id/radioScientist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scientist"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 8 | Def: 1 | Energy: 17"
                android:textSize="12sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="6dp"/>

            <RadioButton
                android:id="@+id/radioSoldier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soldier"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 9 | Def: 0 | Energy: 16"
                android:textSize="12sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="6dp"/>

        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnCreate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create"/>

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>